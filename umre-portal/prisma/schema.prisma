generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model SiteSettings {
  id                    String   @id @default(uuid())
  logoUrl               String?
  faviconUrl            String?
  socialLinks           Json?
  footerDiyanetImageUrl String?
  footerDiyanetLink     String?
  footerAgencyImageUrl  String?
  footerAgencyLink      String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  address               String?
  bankAccounts          Json?
  email                 String?
  firmName              String?
  footerLogos           Json?
  heroSubtitle          String?
  heroTitle             String?
  heroTitleColor        String?  @default("#ffffff")
  heroVideoUrl          String?
  mapEmbedUrl           String?
  mission               String?
  phone                 String?
  phones                Json?
  tourImportantNotes    String?
  vision                String?
}

model MenuItem {
  id         String     @id @default(uuid())
  label      String
  url        String
  parentId   String?
  orderIndex Int
  isActive   Boolean    @default(true)
  parent     MenuItem?  @relation("MenuHierarchy", fields: [parentId], references: [id])
  children   MenuItem[] @relation("MenuHierarchy")
}

model Media {
  id        String   @id @default(uuid())
  url       String
  altText   String?
  type      String
  createdAt DateTime @default(now())
}

model Page {
  id             String    @id @default(uuid())
  title          String
  slug           String    @unique
  status         String    @default("draft")
  seoTitle       String?
  seoDescription String?
  ogImageUrl     String?
  blocks         Json?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  publishedAt    DateTime?
  category       String    @default("general")
  content        String?
  imageUrl       String?
  summary        String?
}

model TourCategory {
  id    String @id @default(uuid())
  name  String
  slug  String @unique
  tours Tour[]
}

model TourType {
  id    String @id @default(uuid())
  name  String
  slug  String @unique
  tours Tour[]
}

model TourItinerary {
  id          String    @id @default(uuid())
  tourId      String
  day         Int
  title       String
  description String?
  locationId  String?
  hotelId     String?
  hotel       Hotel?    @relation(fields: [hotelId], references: [id])
  location    Location? @relation(fields: [locationId], references: [id])
  tour        Tour      @relation(fields: [tourId], references: [id], onDelete: Cascade)
}

model Tour {
  id                String          @id @default(uuid())
  title             String
  slug              String          @unique
  summary           String?
  content           String?
  durationDays      Int
  priceFrom         Decimal?
  currency          String          @default("USD")
  isFeatured        Boolean         @default(false)
  categoryId        String?
  startDates        Json?
  included          Json?
  excluded          Json?
  gallery           Json?
  status            String          @default("draft")
  seoTitle          String?
  seoDescription    String?
  ogImageUrl        String?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  publishedAt       DateTime?
  airline           String?
  departureLocation String?
  durationNights    Int?
  endDate           DateTime?
  excludedText      String?
  label             String?
  locationStays     Json?
  pricing           Json?
  returnDate        DateTime?
  returnLocation    String?
  startDate         DateTime?
  tourTypeId        String?
  vehicleId         String?
  category          TourCategory?   @relation(fields: [categoryId], references: [id])
  tourType          TourType?       @relation(fields: [tourTypeId], references: [id])
  vehicle           Vehicle?        @relation(fields: [vehicleId], references: [id])
  itinerary         TourItinerary[]
}

model Location {
  id          String          @id @default(uuid())
  name        String
  slug        String          @unique
  imageUrl    String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  hotels      Hotel[]
  itineraries TourItinerary[]
}

model HotelFeature {
  id        String   @id @default(uuid())
  name      String
  icon      String?
  category  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  hotels    Hotel[]  @relation("HotelToHotelFeature")
}

model Hotel {
  id               String          @id @default(uuid())
  title            String
  slug             String          @unique
  stars            Int?
  description      String?
  gallery          Json?
  lat              Decimal?
  lng              Decimal?
  isFeatured       Boolean         @default(false)
  status           String          @default("draft")
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  publishedAt      DateTime?
  imageUrl         String?
  locationId       String?
  locationText     String?
  shortDescription String?
  websiteUrl       String?
  location         Location?       @relation(fields: [locationId], references: [id])
  itineraries      TourItinerary[]
  features         HotelFeature[]  @relation("HotelToHotelFeature")
}

model Vehicle {
  id          String    @id @default(uuid())
  modelName   String
  capacity    Int?
  description String?
  imageUrl    String?
  features    Json?
  isFeatured  Boolean   @default(false)
  status      String    @default("draft")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  publishedAt DateTime?
  tours       Tour[]
}

model PostCategory {
  id    String @id @default(uuid())
  name  String
  slug  String @unique
  posts Post[]
}

model Post {
  id             String        @id @default(uuid())
  title          String
  slug           String        @unique
  excerpt        String?
  content        String?
  coverImageUrl  String?
  categoryId     String?
  tags           Json?
  status         String        @default("draft")
  publishedAt    DateTime?
  seoTitle       String?
  seoDescription String?
  ogImageUrl     String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  category       PostCategory? @relation(fields: [categoryId], references: [id])
}

model Testimonial {
  id         String   @id @default(uuid())
  fullName   String
  rating     Int
  comment    String
  avatarUrl  String?
  isFeatured Boolean  @default(false)
  createdAt  DateTime @default(now())
}

model FaqItem {
  id         String  @id @default(uuid())
  question   String
  answer     String
  category   String?
  orderIndex Int
  isActive   Boolean @default(true)
}

model AdminUser {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  role         String
  createdAt    DateTime @default(now())
}

model EmailSettings {
  id                String   @id @default(uuid())
  host              String
  port              Int
  user              String
  pass              String
  fromEmail         String
  notificationEmail String
  updatedAt         DateTime @updatedAt
}

model Comment {
  id          String   @id @default(uuid())
  name        String
  content     String
  rating      Int
  type        String
  entityId    String
  entityName  String?
  isPublished Boolean  @default(false)
  createdAt   DateTime @default(now())
}

model Reservation {
  id          String   @id @default(uuid())
  name        String
  phone       String
  email       String?
  city        String?
  personCount Int
  tourId      String?
  tourName    String?
  note        String?
  status      String   @default("pending")
  createdAt   DateTime @default(now())
}

model CustomTourRequest {
  id                 String    @id @default(uuid())
  fullName           String
  phone              String
  email              String
  personCount        Int
  mekkeDays          Int?
  medineDays         Int?
  startDate          DateTime?
  airline            String?
  flightClass        String?
  departureCity      String?
  hotelChoiceType    String?
  hotelSelection     Json?
  hotelPreference    Json?
  transferChoiceType String?
  vehicleSelection   String?
  transferService    String?
  guideRequested     Boolean   @default(false)
  message            String?
  status             String    @default("pending")
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
}

model PageView {
  id        String   @id @default(uuid())
  path      String
  referrer  String?
  device    String?
  duration  Int?
  sessionId String?
  ip        String?
  createdAt DateTime @default(now())
}

model BlockedIp {
  id        String   @id @default(uuid())
  ip        String   @unique
  reason    String?
  createdAt DateTime @default(now())
}
